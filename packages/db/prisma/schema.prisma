generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppMetadata {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_metadata")
}

model Project {
  id              String       @id @default(cuid())
  name            String
  imageCount      Int          @default(0) @map("image_count")
  labelClassCount Int          @default(0) @map("label_class_count")
  annotationCount Int          @default(0) @map("annotation_count")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  images          Image[]
  labelClasses    LabelClass[]

  @@index([createdAt], map: "projects_created_at_idx")
  @@map("projects")
}

model Image {
  id         String   @id @default(cuid())
  projectId  String   @map("project_id")
  storageKey String   @unique @map("storage_key")
  width      Int
  height     Int
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt], map: "images_project_id_created_at_idx")
  @@map("images")
}

model LabelClass {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  name      String
  color     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name], map: "label_classes_project_id_name_key")
  @@index([projectId, createdAt], map: "label_classes_project_id_created_at_idx")
  @@map("label_classes")
}

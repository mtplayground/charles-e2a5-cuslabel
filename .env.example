# PostgreSQL is required for all persistent state.
DATABASE_URL="postgresql://user:password@host:5432/database"

# Express API listener. Production defaults should be 0.0.0.0:8080 unless your
# platform injects different values.
HOST="0.0.0.0"
PORT="8080"

# Private S3-compatible object storage for uploaded images.
# These are the exact env names read by packages/storage.
OBJECT_STORAGE_ACCESS_KEY_ID=""
OBJECT_STORAGE_SECRET_ACCESS_KEY=""
OBJECT_STORAGE_BUCKET=""
OBJECT_STORAGE_PREFIX="app_your_app_prefix/"
OBJECT_STORAGE_ENDPOINT="https://fly.storage.tigris.dev"
OBJECT_STORAGE_REGION="auto"
OBJECT_STORAGE_FORCE_PATH_STYLE="true"
